{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "cd ../.. && npm run vendor:web",
  "installCommand": "cd ../.. && npm ci",
  "outputDirectory": ".",
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }] }
  ]
}
