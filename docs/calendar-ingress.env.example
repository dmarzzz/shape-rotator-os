# Copy to .env.calendar.local or .env.local, fill values, and keep the filled file out of git.
# Secret values stay blank in this committed example.

# Supabase project
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Seed SQL inputs
ORG_SLUG=shape-rotator
ORG_NAME=Shape Rotator
ADMIN_USER_ID=

# Values returned by seed SQL; needed by web/Electron client config.
ORG_ID=
CALENDAR_CONNECTION_ID=
GUEST_CALENDAR_CONNECTION_ID=

# Google Calendar organizer
# Current default calendar created for launch:
# - name: Shape Rotator OS
# - id: c_d3c51f9ef28351bd0e92449a9d0fa7f4bf27c8a2866309f96c6e2176a50b03ed@group.calendar.google.com
# - timezone: America/New_York
# GOOGLE_CALENDAR_NAME and GOOGLE_CALENDAR_TIMEZONE are operator notes; current
# scripts use GOOGLE_CALENDAR_ID plus the calendar settings in Google.
GOOGLE_CALENDAR_NAME="Shape Rotator OS"
GOOGLE_CALENDAR_ID=c_d3c51f9ef28351bd0e92449a9d0fa7f4bf27c8a2866309f96c6e2176a50b03ed@group.calendar.google.com
GOOGLE_GUEST_CALENDAR_NAME="Shape Rotator Guest Schedule"
GOOGLE_GUEST_CALENDAR_ID=
# Optional explicit override. If omitted, deploy writes this from GOOGLE_GUEST_CALENDAR_ID.
SHAPE_CALENDAR_MEMBER_SUBSCRIBE_URL=
GOOGLE_CALENDAR_TIMEZONE=America/New_York
# Required before applying generated seed SQL. If this stays blank, the seed
# preview uses the placeholder calendar@your-domain.example for inspection only.
GOOGLE_CALENDAR_ORGANIZER_EMAIL=
GOOGLE_CALENDAR_AUTH_MODE=oauth_organizer
# Desired editor ACL targets. Applying writer/owner access still requires an
# OAuth token for an organizer account whose Workspace policy permits sharing.
GOOGLE_CALENDAR_EDITOR_EMAILS=admin-one@example.com,admin-two@example.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth2callback
GOOGLE_OAUTH_SCOPES="https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/meetings.space.settings https://www.googleapis.com/auth/meetings.space.readonly https://www.googleapis.com/auth/userinfo.email openid"
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
# GOOGLE_ACCESS_TOKEN can be used instead of GOOGLE_CALENDAR_ACCESS_TOKEN.
GOOGLE_ACCESS_TOKEN=
GOOGLE_CALENDAR_WEBHOOK_TOKEN=
TRANSCRIPT_WORKER_TOKEN=
TRANSCRIPT_WORKER_LIMIT=5

# Optional
SHAPE_CALENDAR_BOT_EMAIL=cube@shaperotator.xyz
GOOGLE_DRIVE_ARTIFACT_FOLDER_ID=
GOOGLE_DRIVE_ID=
GOOGLE_DRIVE_ADMIN_EMAILS=admin-one@example.com,admin-two@example.com
ROUTING_POLICY_JSON=
TRANSCRIPT_ROOT=
