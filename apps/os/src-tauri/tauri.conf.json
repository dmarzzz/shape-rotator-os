{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shape Rotator OS",
  "version": "../package.json",
  "identifier": "com.shape-rotator.os",
  "build": {
    "beforeDevCommand": "node scripts/tauri-prebuild.cjs",
    "beforeBuildCommand": "node scripts/tauri-prebuild.cjs",
    "frontendDist": "../dist-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Shape Rotator OS",
        "url": "index.html",
        "width": 1600,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://github.com https://avatars.githubusercontent.com; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* https://raw.githubusercontent.com https://api.github.com https://*.phala.network; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/cohort-keys.json": "cohort-keys.json"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
