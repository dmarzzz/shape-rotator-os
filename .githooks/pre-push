#!/bin/sh
# Privacy boundary (layer 4 of 5): re-scan what is about to be pushed. This is
# the backstop for commits made with --no-verify (which skip pre-commit).
#
# Git passes "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin.
ZERO=0000000000000000000000000000000000000000
status=0
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue   # branch deletion, nothing to scan
  if [ "$remote_sha" = "$ZERO" ]; then
    # New branch: scan against origin/main if known, else scan everything.
    base=$(git merge-base origin/main "$local_sha" 2>/dev/null)
    if [ -n "$base" ]; then
      node scripts/check-commit-privacy-boundary.mjs --range "$base..$local_sha" || status=1
    else
      node scripts/check-commit-privacy-boundary.mjs --all || status=1
    fi
  else
    node scripts/check-commit-privacy-boundary.mjs --range "$remote_sha..$local_sha" || status=1
  fi
done
exit $status
